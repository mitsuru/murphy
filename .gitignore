# Git worktrees (isolated workspaces)
.worktrees/

# Rust build output (root workspace, spikes, any crate)
target/
*.gem
.DS_Store
# Stray artifact emitted in CWD by `cargo test`'s merged doctest compilation.
librust_out.rlib

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Antigravity CLI scratch dir
.antigravitycli/

# Claude session worktrees (analogous to .worktrees/)
.claude/worktrees/
